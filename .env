# =============================================
# Configurações Gerais da Aplicação
# =============================================
APP_NAME="Sua Aplicação"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://seu-dominio.com

# =============================================
# Banco de Dados PostgreSQL
# =============================================
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=seu_banco
DB_USERNAME=seu_user
DB_PASSWORD=SuaSenhaForte123!

# =============================================
# Redis (Sessões e Cache)
# =============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Configurações de Sessão (Laravel ou similar)
SESSION_DRIVER=redis
SESSION_LIFETIME=1440

# Cache
CACHE_DRIVER=redis

# =============================================
# PHP Config
# =============================================
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX=64M
PHP_MAX_EXECUTION_TIME=120

# =============================================
# Domínio e SSL (Let's Encrypt)
# =============================================
DOMAIN=seu-dominio.com
WWW_DOMAIN=www.seu-dominio.com
EMAIL_LETSENCRYPT=seuemail@dominio.com

# =============================================
# Scale (Picos mensais)
# =============================================
NORMAL_PHP_REPLICAS=4
PEAK_PHP_REPLICAS=12
PEAK_DAYS=15,16

# =============================================
# Outras Configurações
# =============================================
TZ=America/Sao_Paulo
